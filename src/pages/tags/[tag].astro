---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, getAllTags, getPublishedPosts, postToSlug, tagToSlug } from '@/utils/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getAllTags(posts);

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter((post) =>
  post.data.tags.some((item) => tagToSlug(item) === tag.slug)
);
---

<BaseLayout title={`标签：${tag.name}`} description={`浏览 ${tag.name} 标签下的文章。`}>
  <section class="mb-8">
    <p class="mb-2 text-sm font-semibold text-accent">Tag</p>
    <h1 class="text-4xl font-black tracking-normal text-ink">{tag.name}</h1>
    <p class="mt-3 text-lg text-muted">{posts.length} 篇文章</p>
  </section>

  <div class="grid gap-5">
    {
      posts.map((post) => (
        <article data-animate="card" data-tilt-card class="glass-card rounded-lg p-5 transition">
          <time class="text-sm text-muted" datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          <h2 class="mt-3 text-2xl font-bold text-ink">
            <a href={post.data.redirectUrl ?? `/blog/${postToSlug(post)}/`}>{post.data.title}</a>
          </h2>
          <p class="mt-2 leading-7 text-muted">{post.data.description}</p>
        </article>
      ))
    }
  </div>
</BaseLayout>
