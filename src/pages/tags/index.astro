---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllTags, getPublishedPosts } from '@/utils/content';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="标签" description="按标签浏览文章。">
  <section class="mb-8">
    <h1 class="text-4xl font-black tracking-normal text-ink">标签</h1>
    <p class="mt-3 text-lg text-muted">按主题整理所有文章。</p>
  </section>

  <div class="flex flex-wrap gap-3">
    {
      tags.map((tag) => (
        <a
          data-animate="card"
          data-tilt-card
          class="glass-card rounded-md px-4 py-3 text-muted transition hover:text-accent"
          href={`/tags/${tag.slug}/`}
        >
          {tag.name} · {tag.count}
        </a>
      ))
    }
  </div>
</BaseLayout>
