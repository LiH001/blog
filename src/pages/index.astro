---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ShaderAnimation from '@/components/ShaderAnimation.astro';
import { siteConfig } from '@/site.config';
import { formatDate, getAllTags, getPublishedPosts, postToSlug, tagToSlug } from '@/utils/content';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
const tags = getAllTags(posts).slice(0, 10);
---

<BaseLayout>
  <section class="mb-14 grid gap-6 lg:grid-cols-[1fr_340px] lg:items-stretch">
    <div class="glass-panel rounded-lg p-6 sm:p-8">
      <div data-animate="hero" class="mb-7 flex flex-wrap items-center gap-4">
        <img
          data-float
          class="soft-ring size-20 rounded-lg object-cover"
          src={siteConfig.author.avatar}
          alt={`${siteConfig.author.name} 的头像`}
        />
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">{siteConfig.name}</p>
          <p class="mt-2 text-xl font-bold text-ink">{siteConfig.author.name}</p>
          <p class="mt-1 text-sm text-muted">{siteConfig.author.role}</p>
        </div>
      </div>
      <h1 data-animate="hero" class="max-w-3xl text-4xl font-black leading-tight tracking-normal text-ink sm:text-6xl">
        整理一下相关笔记。
      </h1>
      <p data-animate="hero" class="mt-5 max-w-2xl text-lg leading-8 text-muted">
        {siteConfig.author.bio}
      </p>
      <div data-animate="hero" class="mt-8 flex flex-wrap gap-3">
        <a class="rounded-md bg-accent px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-ink" href="/blog/">
          阅读文章
        </a>
        <a class="rounded-md border border-white/70 bg-white/60 px-4 py-3 text-sm font-semibold text-ink backdrop-blur transition hover:border-accent hover:text-accent" href="/about/">
          关于我
        </a>
      </div>
      <div data-animate="hero" class="mt-8 flex flex-wrap gap-3" aria-label="内容技术栈">
        <span class="motion-chip" data-float>Astro</span>
        <span class="motion-chip" data-float>TypeScript</span>
        <span class="motion-chip" data-float>MDX</span>
      </div>
    </div>
    <div data-tilt-card class="glass-card rounded-lg p-6">
      <ShaderAnimation class="mb-5 h-56 rounded-md border border-white/70 dark:border-white/10 shadow-sm" label="Blog shader animation" />
      <p class="text-sm font-semibold text-accent">当前站点</p>
      <div class="mt-5 grid grid-cols-2 gap-3">
        <div class="rounded-lg bg-white/55 dark:bg-white/5 p-4">
          <p class="text-sm text-muted">文章</p>
          <p class="mt-2 text-3xl font-black text-ink">{posts.length}</p>
        </div>
        <div class="rounded-lg bg-white/55 dark:bg-white/5 p-4">
          <p class="text-sm text-muted">标签</p>
          <p class="mt-2 text-3xl font-black text-ink">{tags.length}</p>
        </div>
      </div>
      <p class="mt-5 leading-7 text-muted">
        内容全部来自 Markdown / MDX，适合快速写作、Git 管理和静态部署。
      </p>
      <div class="mt-6 rounded-lg border border-white/70 dark:border-white/10 bg-white/45 dark:bg-white/5 p-4">
        <div class="mb-3 flex items-center justify-between text-xs font-semibold uppercase text-muted">
          <span>Writing pulse</span>
          <span>Live</span>
        </div>
        <div class="flex h-24 items-end gap-2">
          <span data-wave class="signal-bar h-10"></span>
          <span data-wave class="signal-bar h-16"></span>
          <span data-wave class="signal-bar h-8"></span>
          <span data-wave class="signal-bar h-20"></span>
          <span data-wave class="signal-bar h-12"></span>
          <span data-wave class="signal-bar h-18"></span>
          <span data-wave class="signal-bar h-14"></span>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-14">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-bold text-ink">最新文章</h2>
        <p class="mt-1 text-sm text-muted">最近写下来的想法和实践。</p>
      </div>
      <a class="text-sm font-semibold text-accent hover:underline" href="/blog/">全部</a>
    </div>
    <div class="grid gap-5">
      {
        latestPosts.map((post) => (
          <article
            data-animate="card"
            data-tilt-card
            class:list={[
              "glass-card rounded-lg p-5 transition",
              post.data.cover ? "grid gap-5 sm:grid-cols-[180px_1fr]" : "block"
            ]}
          >
            {
              post.data.cover && (
                <a href={post.data.redirectUrl ?? `/blog/${postToSlug(post)}/`}>
                  <img
                    class="aspect-[16/10] w-full rounded-md border border-white/70 dark:border-white/10 object-cover"
                    src={post.data.cover}
                    alt={post.data.coverAlt ?? post.data.title}
                    loading="lazy"
                  />
                </a>
              )
            }
            <div>
            <div class="mb-3 flex flex-wrap items-center gap-3 text-sm text-muted">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              {post.data.tags.slice(0, 3).map((tag) => (
                <a href={`/tags/${tagToSlug(tag)}/`} class="hover:text-accent">
                  #{tag}
                </a>
              ))}
            </div>
            <h3 class="text-xl font-bold text-ink">
              <a href={post.data.redirectUrl ?? `/blog/${postToSlug(post)}/`}>{post.data.title}</a>
            </h3>
            <p class="mt-2 leading-7 text-muted">{post.data.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section>
    <h2 class="mb-4 text-2xl font-bold text-ink">标签</h2>
    <div class="flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <a
            data-animate="card"
            class="rounded-md border border-white/70 bg-white/55 px-3 py-2 text-sm text-muted backdrop-blur transition hover:border-accent hover:text-accent"
            href={`/tags/${tag.slug}/`}
          >
            {tag.name} · {tag.count}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
