---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, getPublishedPosts, postToSlug, tagToSlug } from '@/utils/content';

const posts = await getPublishedPosts();
---

<BaseLayout title="文章" description="所有技术文章、项目复盘和学习笔记。">
  <section class="mb-8">
    <h1 class="text-4xl font-black tracking-normal text-ink">文章</h1>
    <p class="mt-3 text-lg text-muted">所有技术文章、项目复盘和学习笔记。</p>
  </section>

  <div class="grid gap-6">
    {
      posts.map((post) => (
        <article
          data-animate="card"
          data-tilt-card
          class:list={[
            "glass-card rounded-lg p-5 transition",
            post.data.cover ? "grid gap-5 sm:grid-cols-[220px_1fr]" : "block"
          ]}
        >
          {
            post.data.cover && (
              <a href={post.data.redirectUrl ?? `/blog/${postToSlug(post)}/`}>
                <img
                  class="aspect-[16/10] w-full rounded-md border border-white/70 object-cover"
                  src={post.data.cover}
                  alt={post.data.coverAlt ?? post.data.title}
                  loading="lazy"
                />
              </a>
            )
          }
          <div>
            <div class="mb-3 flex flex-wrap items-center gap-3 text-sm text-muted">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              {post.data.tags.map((tag) => (
                <a class="hover:text-accent" href={`/tags/${tagToSlug(tag)}/`}>
                  #{tag}
                </a>
              ))}
            </div>
            <h2 class="text-2xl font-bold text-ink">
              <a href={post.data.redirectUrl ?? `/blog/${postToSlug(post)}/`}>{post.data.title}</a>
            </h2>
            <p class="mt-3 leading-7 text-muted">{post.data.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
