---
import type { MarkdownHeading } from 'astro';
import type { BlogPost } from '@/utils/content';
import { formatDate, tagToSlug } from '@/utils/content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  post: BlogPost;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.cover}
  type="article"
>
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']]
      }
    };
  </script>
  <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

  <article class="mx-auto max-w-4xl">
    <header class="mb-8">
      <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-muted">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        {
          post.data.tags.map((tag) => (
            <a
              class="rounded-md border border-line bg-surface px-2.5 py-1 hover:border-accent hover:text-accent"
              href={`/tags/${tagToSlug(tag)}/`}
            >
              {tag}
            </a>
          ))
        }
      </div>
      <h1 class="max-w-3xl text-4xl font-black leading-tight tracking-normal text-ink sm:text-5xl">
        {post.data.title}
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-muted">{post.data.description}</p>
    </header>

    {
      post.data.cover && (
        <img
          src={post.data.cover}
          alt={post.data.coverAlt ?? post.data.title}
          class="mb-10 aspect-[1200/630] w-full rounded-lg border border-line object-cover"
          loading="eager"
        />
      )
    }

    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_220px]">
      <div class="prose max-w-none">
        <slot />
      </div>
      {
        visibleHeadings.length > 0 && (
          <aside class="hidden lg:block">
            <div class="glass-card sticky top-24 rounded-lg p-5 text-sm">
              <p class="mb-3 font-semibold text-ink">目录</p>
              <nav class="flex flex-col gap-2 text-muted" aria-label="文章目录">
                {visibleHeadings.map((heading) => (
                  <a
                    class:list={[
                      'hover:text-accent',
                      heading.depth === 3 && 'pl-3'
                    ]}
                    href={`#${heading.slug}`}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )
      }
    </div>
  </article>
</BaseLayout>
