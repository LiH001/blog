---
import '@/styles/global.css';
import { siteConfig } from '@/site.config';
import ThemeToggle from '@/components/ThemeToggle.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const siteName = siteConfig.title;
const {
  title = siteName,
  description = siteConfig.description,
  image = '/covers/astro-blog.svg',
  type = 'website'
} = Astro.props;

const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const siteUrl = Astro.site ?? Astro.url.origin;
const canonical = new URL(Astro.url.pathname, siteUrl);
const imageUrl = new URL(image, siteUrl);
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog/', label: '文章' },
  { href: '/tags/', label: '标签' },
  { href: '/projects/', label: '项目' },
  { href: '/about/', label: '关于' }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      const getTheme = () => {
        const saved = localStorage.getItem('theme');
        if (saved && saved !== 'system') return saved;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const isDark = getTheme() === 'dark';
      document.documentElement.classList.toggle('dark', isDark);
      document.documentElement.dataset.theme = localStorage.getItem('theme') || 'system';
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body>
    <header class="sticky top-0 z-20 border-b border-white/50 dark:border-white/10 bg-paper/70 backdrop-blur-xl">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
        <a href="/" class="flex items-center gap-3 text-base font-bold tracking-normal text-ink" aria-label="返回首页">
          <img class="size-9 rounded-md border border-white/70 dark:border-white/10 shadow-sm" src={siteConfig.author.avatar} alt="" data-float />
          <span>{siteConfig.name}</span>
        </a>
        <div class="flex items-center gap-4 justify-between sm:justify-end flex-wrap sm:flex-nowrap">
          <nav class="flex flex-wrap gap-1 text-sm text-muted" aria-label="主导航">
            {
              navItems.map((item) => {
                const active =
                  item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
                return (
                  <a
                    href={item.href}
                    class:list={[
                      'rounded-md px-3 py-2 transition hover:bg-white/70 hover:text-accent dark:hover:bg-white/10',
                      active && 'bg-white/80 text-accent shadow-sm dark:bg-white/10 dark:text-accent'
                    ]}
                  >
                    {item.label}
                  </a>
                );
              })
            }
          </nav>
          <ThemeToggle />
        </div>
      </div>
    </header>
    <main class="mx-auto w-full max-w-6xl px-5 py-10 sm:py-14">
      <slot />
    </main>
    <footer class="border-t border-white/60 dark:border-white/10 bg-white/30 dark:bg-white/5 backdrop-blur">
      <div class="mx-auto flex max-w-6xl flex-col gap-2 px-5 py-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
        <p>© {new Date().getFullYear()} {siteConfig.name}</p>
        <a class="hover:text-accent" href="/rss.xml">RSS</a>
      </div>
    </footer>
    <script>
      import '../scripts/animations';
    </script>
  </body>
</html>
