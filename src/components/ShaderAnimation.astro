---
interface Props {
  label?: string;
  class?: string;
}

const { label = 'Shader animation', class: className = '' } = Astro.props;
---

<div class:list={['shader-animation', className]} data-shader-animation aria-label={label}>
  <span class="sr-only">{label}</span>
</div>

<script>
  import * as THREE from 'three';

  const vertexShader = `
    void main() {
      gl_Position = vec4(position, 1.0);
    }
  `;

  const fragmentShader = `
    precision highp float;

    uniform vec2 resolution;
    uniform float time;

    void main(void) {
      vec2 uv = (gl_FragCoord.xy * 2.0 - resolution.xy) / min(resolution.x, resolution.y);
      float t = time * 0.05;
      float lineWidth = 0.002;

      vec3 color = vec3(0.0);
      for (int j = 0; j < 3; j++) {
        for (int i = 0; i < 5; i++) {
          color[j] += lineWidth * float(i * i) / abs(fract(t - 0.01 * float(j) + float(i) * 0.01) * 5.0 - length(uv) + mod(uv.x + uv.y, 0.2));
        }
      }

      gl_FragColor = vec4(color[0], color[1], color[2], 1.0);
    }
  `;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  document.querySelectorAll<HTMLElement>('[data-shader-animation]').forEach((container) => {
    if (container.dataset.shaderReady === 'true') return;
    container.dataset.shaderReady = 'true';

    const camera = new THREE.Camera();
    camera.position.z = 1;

    const scene = new THREE.Scene();
    const geometry = new THREE.PlaneGeometry(2, 2);
    const uniforms = {
      time: { value: 1.0 },
      resolution: { value: new THREE.Vector2() }
    };

    const material = new THREE.ShaderMaterial({
      uniforms,
      vertexShader,
      fragmentShader
    });

    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);
    // --- LiH text mesh ---
    const textCanvas = document.createElement('canvas');
    textCanvas.width = 512;
    textCanvas.height = 128;
    const tctx = textCanvas.getContext('2d');
    tctx.fillStyle = 'rgba(255, 255, 255, 0.95)';
    tctx.font = 'bold 96px "Segoe UI", system-ui, sans-serif';
    tctx.textAlign = 'center';
    tctx.textBaseline = 'middle';
    tctx.fillText('LiH', 256, 64);

    const textTexture = new THREE.CanvasTexture(textCanvas);
    textTexture.minFilter = THREE.LinearFilter;
    textTexture.magFilter = THREE.LinearFilter;

    const textVertexShader = `
      varying vec2 vUv;
      varying vec3 vPos;
      uniform float time;
      void main() {
        vUv = uv;
        vec3 pos = position;
        pos.x += sin(pos.y * 10.0 + time * 0.15) * 0.015;
        pos.y += cos(pos.x * 10.0 + time * 0.12) * 0.015;
        vPos = pos;
        gl_Position = vec4(pos, 1.0);
      }
    `;

    const textFragmentShader = `
      precision highp float;
      varying vec2 vUv;
      varying vec3 vPos;
      uniform float time;
      uniform sampler2D tex;
      void main() {
        vec4 texColor = texture2D(tex, vUv);
        float pulse = 0.55 + 0.45 * sin(time * 0.12);
        float glow = 0.6 + 0.4 * sin(time * 0.18 + 1.5);
        vec3 glowColor = vec3(0.45, 0.35, 0.95) * glow * texColor.a;
        vec3 finalColor = mix(texColor.rgb, glowColor + texColor.rgb, glow * 0.5);
        float alpha = texColor.a * (0.75 + pulse * 0.25);
        gl_FragColor = vec4(finalColor, alpha);
      }
    `;

    const textGeometry = new THREE.PlaneGeometry(1.6, 0.4);
    const textMaterial = new THREE.ShaderMaterial({
      uniforms: {
        time: uniforms.time,
        tex: { value: textTexture }
      },
      vertexShader: textVertexShader,
      fragmentShader: textFragmentShader,
      transparent: true,
      depthTest: false,
      depthWrite: false
    });

    const textMesh = new THREE.Mesh(textGeometry, textMaterial);
    textMesh.position.z = 0.02;
    scene.add(textMesh);


    const renderer = new THREE.WebGLRenderer({
      antialias: true,
      alpha: false,
      powerPreference: 'high-performance'
    });

    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    let animationId = 0;

    const resize = () => {
      const width = Math.max(container.clientWidth, 1);
      const height = Math.max(container.clientHeight, 1);
      renderer.setSize(width, height, false);
      uniforms.resolution.value.set(renderer.domElement.width, renderer.domElement.height);
    };

    const render = () => {
      uniforms.time.value += prefersReducedMotion.matches ? 0 : 0.05;
      renderer.render(scene, camera);
    };

    const animate = () => {
      render();
      animationId = window.requestAnimationFrame(animate);
    };

    const resizeObserver = new ResizeObserver(() => {
      resize();
      render();
    });

    resizeObserver.observe(container);
    resize();
    render();

    if (!prefersReducedMotion.matches) {
      animationId = window.requestAnimationFrame(animate);
    }

    const onMotionChange = () => {
      window.cancelAnimationFrame(animationId);
      if (prefersReducedMotion.matches) {
        render();
        return;
      }
      animationId = window.requestAnimationFrame(animate);
    };

    prefersReducedMotion.addEventListener('change', onMotionChange);

    document.addEventListener(
      'astro:before-swap',
      () => {
        prefersReducedMotion.removeEventListener('change', onMotionChange);
        resizeObserver.disconnect();
        window.cancelAnimationFrame(animationId);
        renderer.dispose();
        geometry.dispose();
        material.dispose();
        textGeometry.dispose();
        textMaterial.dispose();
        textTexture.dispose();
      },
      { once: true }
    );
  });
</script>

<style>
  .shader-animation {
    position: relative;
    min-height: 14rem;
    overflow: hidden;
    background: #020617;
    isolation: isolate;
  }

  .shader-animation :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }

</style>
