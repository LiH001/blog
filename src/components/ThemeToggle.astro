<div class="relative inline-block text-left" data-theme-dropdown>
  <button
    type="button"
    class="flex items-center gap-2 rounded-md border border-white/50 bg-white/40 px-3 py-1.5 text-xs font-semibold text-muted backdrop-blur transition hover:border-accent hover:text-accent dark:border-white/10 dark:bg-white/5 dark:hover:border-accent"
    aria-expanded="false"
    aria-haspopup="true"
    data-theme-btn
  >
    <!-- Sun Icon -->
    <svg class="theme-icon-sun size-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
    </svg>
    <!-- Moon Icon -->
    <svg class="theme-icon-moon size-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
    </svg>
    <!-- Monitor Icon (System) -->
    <svg class="theme-icon-system size-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect width="20" height="14" x="2" y="3" rx="2"></rect>
      <line x1="8" x2="16" y1="21" y2="21"></line>
      <line x1="12" x2="12" y1="17" y2="21"></line>
    </svg>
    <span data-theme-label>主题</span>
    <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </button>

  <div
    class="absolute right-0 mt-2 w-32 origin-top-right rounded-md border border-white/50 bg-white/95 p-1 shadow-lg ring-1 ring-black/5 focus:outline-none transition-all scale-95 opacity-0 pointer-events-none z-50 dark:border-white/10 dark:bg-slate-900/95"
    role="menu"
    aria-orientation="vertical"
    data-theme-menu
  >
    <button
      class="flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-left text-xs text-muted hover:bg-accent-soft hover:text-accent dark:hover:bg-white/10"
      role="menuitem"
      data-theme-option="light"
    >
      <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
      </svg>
      浅色
    </button>
    <button
      class="flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-left text-xs text-muted hover:bg-accent-soft hover:text-accent dark:hover:bg-white/10"
      role="menuitem"
      data-theme-option="dark"
    >
      <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
      </svg>
      深色
    </button>
    <button
      class="flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-left text-xs text-muted hover:bg-accent-soft hover:text-accent dark:hover:bg-white/10"
      role="menuitem"
      data-theme-option="system"
    >
      <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="20" height="14" x="2" y="3" rx="2"></rect>
        <line x1="8" x2="16" y1="21" y2="21"></line>
        <line x1="12" x2="12" y1="17" y2="21"></line>
      </svg>
      跟随系统
    </button>
  </div>
</div>

<script>
  const initThemeToggle = () => {
    const dropdown = document.querySelector('[data-theme-dropdown]');
    if (!dropdown) return;

    const btn = dropdown.querySelector('[data-theme-btn]') as HTMLButtonElement;
    const menu = dropdown.querySelector('[data-theme-menu]') as HTMLDivElement;
    const options = dropdown.querySelectorAll('[data-theme-option]');
    const label = dropdown.querySelector('[data-theme-label]') as HTMLSpanElement;

    // Toggle menu
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = btn.getAttribute('aria-expanded') === 'true';
      if (open) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    const openMenu = () => {
      btn.setAttribute('aria-expanded', 'true');
      menu.classList.remove('scale-95', 'opacity-0', 'pointer-events-none');
      menu.classList.add('scale-100', 'opacity-100');
    };

    const closeMenu = () => {
      btn.setAttribute('aria-expanded', 'false');
      menu.classList.remove('scale-100', 'opacity-100');
      menu.classList.add('scale-95', 'opacity-0', 'pointer-events-none');
    };

    document.addEventListener('click', closeMenu);

    // Update active state and label based on localStorage / DOM dataset
    const updateDropdownUI = () => {
      const currentTheme = document.documentElement.dataset.theme || 'system';
      
      // Update label
      if (currentTheme === 'light') {
        label.textContent = '浅色';
        dropdown.querySelector('.theme-icon-sun')?.classList.remove('hidden');
        dropdown.querySelector('.theme-icon-moon')?.classList.add('hidden');
        dropdown.querySelector('.theme-icon-system')?.classList.add('hidden');
      } else if (currentTheme === 'dark') {
        label.textContent = '深色';
        dropdown.querySelector('.theme-icon-sun')?.classList.add('hidden');
        dropdown.querySelector('.theme-icon-moon')?.classList.remove('hidden');
        dropdown.querySelector('.theme-icon-system')?.classList.add('hidden');
      } else {
        label.textContent = '跟随系统';
        dropdown.querySelector('.theme-icon-sun')?.classList.add('hidden');
        dropdown.querySelector('.theme-icon-moon')?.classList.add('hidden');
        dropdown.querySelector('.theme-icon-system')?.classList.remove('hidden');
      }

      // Highlight active option
      options.forEach(opt => {
        const themeVal = opt.getAttribute('data-theme-option');
        if (themeVal === currentTheme) {
          opt.classList.add('text-accent', 'font-semibold', 'bg-accent-soft', 'dark:bg-white/5');
        } else {
          opt.classList.remove('text-accent', 'font-semibold', 'bg-accent-soft', 'dark:bg-white/5');
        }
      });
    };

    updateDropdownUI();

    // Handle option click
    options.forEach(opt => {
      opt.addEventListener('click', () => {
        const themeVal = opt.getAttribute('data-theme-option') || 'system';
        localStorage.setItem('theme', themeVal);
        
        let isDark = false;
        if (themeVal === 'system') {
          isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        } else {
          isDark = themeVal === 'dark';
        }
        document.documentElement.classList.toggle('dark', isDark);
        document.documentElement.dataset.theme = themeVal;
        
        // Also dispatch custom event for components like ShaderAnimation that might want to react
        window.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: themeVal, isDark } }));

        updateDropdownUI();
        closeMenu();
      });
    });

    // Listen for system theme changes if set to system
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      const currentTheme = localStorage.getItem('theme') || 'system';
      if (currentTheme === 'system') {
        const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', isDark);
        window.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: 'system', isDark } }));
      }
    });
  };

  // Run on page load and after page transitions (Astro view transitions support)
  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
